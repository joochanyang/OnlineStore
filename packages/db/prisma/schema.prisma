generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FULFILLING
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
  CANCELLED
}

enum AdminRole {
  OWNER
  MERCHANDISER
  FULFILLMENT
  SUPPORT
  ANALYST
}

enum SupplierImportStatus {
  IMPORTED
  NEEDS_REVIEW
  APPROVED
  REJECTED
}

enum AuthProvider {
  PASSWORD
  KAKAO
  NAVER
  GOOGLE
  APPLE
}

enum ActorType {
  ADMIN
  CUSTOMER
  SYSTEM
}

enum ConsentType {
  TERMS
  PRIVACY
  MARKETING_SMS
  MARKETING_EMAIL
  MARKETING_PUSH
  AGE_14_PLUS
}

enum ConsentSource {
  SIGNUP
  CHECKOUT
  ACCOUNT
  ADMIN_ADJUSTMENT
}

enum FulfillmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Product {
  id                 String                     @id @default(cuid())
  slug               String                     @unique
  name               String
  description        String?
  status             ProductStatus              @default(DRAFT)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  categories         ProductCategory[]
  images             ProductImage[]
  variants           ProductVariant[]
  supplierCandidates SupplierProductCandidate[]
}

model ProductVariant {
  id             String                 @id @default(cuid())
  productId      String
  sku            String                 @unique
  color          String
  size           String
  price          Int
  compareAtPrice Int?
  stock          Int
  safetyStock    Int                    @default(0)
  product        Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  reservations   InventoryReservation[]
  orderLines     OrderLine[]
  cartItems      CartItem[]

  @@index([productId])
}

model Category {
  id        String            @id @default(cuid())
  slug      String            @unique
  name      String
  createdAt DateTime          @default(now())
  products  ProductCategory[]
}

model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model InventoryReservation {
  id        String         @id @default(cuid())
  variantId String
  quantity  Int
  reason    String
  expiresAt DateTime?
  createdAt DateTime       @default(now())
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([expiresAt])
}

model Customer {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String
  phone              String?
  passwordHash       String?
  authProvider       AuthProvider        @default(PASSWORD)
  providerUserId     String?
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  mfaSecret          String?
  mfaEnabledAt       DateTime?
  lastLoginAt        DateTime?
  dormantAt          DateTime?
  disabledAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  addresses          Address[]
  orders             Order[]
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]
  consents           ConsentRecord[]
  cart               Cart?

  @@unique([authProvider, providerUserId], name: "customer_provider_unique")
  @@index([dormantAt])
  @@index([disabledAt])
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  recipient  String
  phone      String
  postalCode String
  line1      String
  line2      String?
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Order {
  id            String      @id @default(cuid())
  customerId    String
  status        OrderStatus @default(DRAFT)
  subtotalPrice Int
  shippingFee   Int         @default(0)
  discountPrice Int         @default(0)
  totalPrice    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  paidAt        DateTime?
  customer      Customer    @relation(fields: [customerId], references: [id])
  lines         OrderLine[]
  payments      Payment[]
  shipments     Shipment[]

  @@index([customerId])
  @@index([status, createdAt])
}

model OrderLine {
  id           String                 @id @default(cuid())
  orderId      String
  variantId    String
  quantity     Int
  unitPrice    Int
  order        Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant      ProductVariant         @relation(fields: [variantId], references: [id])
  fulfillments OrderLineFulfillment[]
  refunds      OrderLineRefund[]

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id             String          @id @default(cuid())
  orderId        String
  provider       String
  externalId     String          @unique
  idempotencyKey String?         @unique
  amount         Int
  approvedAt     DateTime?
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds        PaymentRefund[]

  @@index([orderId])
}

model Shipment {
  id             String                 @id @default(cuid())
  orderId        String
  carrier        String
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  lastTrackedAt  DateTime?
  statusDetail   String?
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fulfillments   OrderLineFulfillment[]

  @@index([orderId])
  @@index([orderId, lastTrackedAt])
}

model AdminUser {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String?
  roles         AdminRole[]
  mfaSecret     String?
  mfaEnabledAt  DateTime?
  lastLoginAt   DateTime?
  disabledAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@index([disabledAt])
}

model RefreshToken {
  id           String     @id @default(cuid())
  actorType    ActorType
  customerId   String?
  adminUserId  String?
  tokenHash    String     @unique
  family       String
  replacedById String?
  revokedAt    DateTime?
  expiresAt    DateTime
  ip           String?
  userAgent    String?
  createdAt    DateTime   @default(now())
  customer     Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  adminUser    AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([family])
  @@index([customerId, revokedAt])
  @@index([adminUserId, revokedAt])
  @@index([expiresAt])
}

model EmailVerification {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model PasswordReset {
  id         String    @id @default(cuid())
  customerId String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  ip         String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model ConsentRecord {
  id         String        @id @default(cuid())
  customerId String
  type       ConsentType
  granted    Boolean
  source     ConsentSource
  ip         String?
  userAgent  String?
  recordedAt DateTime      @default(now())
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type, recordedAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorType  ActorType
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime  @default(now())

  @@index([actorType, actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
}

model Supplier {
  id         String                     @id @default(cuid())
  name       String
  mode       String
  endpoint   String?
  createdAt  DateTime                   @default(now())
  candidates SupplierProductCandidate[]
}

model SupplierProductCandidate {
  id         String               @id @default(cuid())
  supplierId String
  productId  String?
  externalId String
  name       String
  rawPayload Json
  status     SupplierImportStatus @default(IMPORTED)
  createdAt  DateTime             @default(now())
  supplier   Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product    Product?             @relation(fields: [productId], references: [id])

  @@unique([supplierId, externalId])
  @@index([status])
}

model Cart {
  id             String     @id @default(cuid())
  customerId     String?    @unique
  anonymousToken String?    @unique
  expiresAt      DateTime
  lastActivityAt DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  customer       Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items          CartItem[]

  @@index([expiresAt])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int
  addedAt   DateTime       @default(now())
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, variantId])
  @@index([cartId])
}

model OrderLineFulfillment {
  id          String            @id @default(cuid())
  orderLineId String
  shipmentId  String?
  quantity    Int
  status      FulfillmentStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  orderLine   OrderLine         @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  shipment    Shipment?         @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([orderLineId])
  @@index([shipmentId])
  @@index([status])
}

model OrderLineRefund {
  id              String        @id @default(cuid())
  orderLineId     String
  paymentRefundId String
  quantity        Int
  status          RefundStatus  @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderLine       OrderLine     @relation(fields: [orderLineId], references: [id], onDelete: Cascade)
  paymentRefund   PaymentRefund @relation(fields: [paymentRefundId], references: [id], onDelete: Cascade)

  @@index([orderLineId])
  @@index([paymentRefundId])
}

model PaymentRefund {
  id               String            @id @default(cuid())
  paymentId        String
  externalRefundId String            @unique
  amount           Int
  reason           String
  status           RefundStatus      @default(PENDING)
  requestedAt      DateTime          @default(now())
  completedAt      DateTime?
  payment          Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  lineRefunds      OrderLineRefund[]

  @@index([paymentId])
  @@index([status, requestedAt])
}

model WebhookEvent {
  id                  String    @id @default(cuid())
  provider            String
  externalId          String
  signatureVerifiedAt DateTime?
  payload             Json
  processedAt         DateTime?
  error               String?
  receivedAt          DateTime  @default(now())

  @@unique([provider, externalId])
  @@index([provider, processedAt])
  @@index([receivedAt])
}

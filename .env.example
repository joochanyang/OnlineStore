# --- App ---
NODE_ENV=development
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# --- Database (Supabase Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/commerce
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/commerce

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Auth ---
# 64+ hex chars. Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
AUTH_JWT_SECRET=
# 64+ hex chars. Distinct from AUTH_JWT_SECRET.
AUTH_CSRF_SECRET=
AUTH_ISSUER=commerce-platform
AUTH_AUDIENCE_WEB=commerce-web
AUTH_AUDIENCE_ADMIN=commerce-admin

# OAuth providers (Auth.js v5)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# --- Payments (Toss Payments) ---
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=
PAYMENT_MODE=mock
# mock | sandbox | live

# --- Object Storage / CDN (Cloudflare R2 + Images) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=commerce-assets
R2_PUBLIC_BASE_URL=
CLOUDFLARE_IMAGES_ACCOUNT_HASH=
CLOUDFLARE_IMAGES_TOKEN=

# --- Cache / Rate limit (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Search (Meilisearch) ---
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="Commerce <noreply@example.com>"

# --- 알림톡 / SMS (Solapi primary, NHN Cloud SENS fallback) ---
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
SOLAPI_PFID=
NCLOUD_SENS_ACCESS_KEY=
NCLOUD_SENS_SECRET_KEY=
NCLOUD_SENS_SERVICE_ID=

# --- Push (Expo + FCM/APNs) ---
EXPO_ACCESS_TOKEN=
FCM_SERVER_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=

# --- AI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_DAILY_USD_CAP=3
AI_MONTHLY_USD_CAP=80

# --- Observability ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# --- Workflow ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Misc ---
ADMIN_DEV_ACTOR_ID=
SUPPLIER_IMPORT_SECRET=
